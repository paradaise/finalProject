# ─── Sound Sentinel — Переменные окружения ───────────────────────────────────
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ── Сеть ─────────────────────────────────────────────────────────────────────
# IP-адрес машины, где запущен backend
# Важно: это должен быть IP, доступный из браузера пользователя (не localhost)
API_HOST=192.168.0.86
API_PORT=8000
USE_SSL=true

# ── SSL ───────────────────────────────────────────────────────────────────────
# Пути к сертификатам (генерируются скриптом ./scripts/gen_certs.sh)
SSL_KEY=./mvp_sound_sentinel/backend/certs/key.pem
SSL_CERT=./mvp_sound_sentinel/backend/certs/cert.pem

# ── База данных ───────────────────────────────────────────────────────────────
DB_PATH=./data/db/sound_sentinel.db

# ── Детекция ──────────────────────────────────────────────────────────────────
# Минимальная уверенность YAMNet для сохранения детекции (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.3

# Минимальная косинусная схожесть для кастомных звуков (0.0 – 1.0)
CUSTOM_MATCH_DEFAULT_THRESHOLD=0.7

# ── YAMNet ────────────────────────────────────────────────────────────────────
#YAMNET_TF_HUB_URL=https://tfhub.dev/google/yamnet/1
YAMNET_CACHE_DIR=./data/yamnet-cache

# ── CORS ──────────────────────────────────────────────────────────────────────
# Разрешённые источники (через запятую)
CORS_ORIGINS=https://localhost:3000,https://192.168.0.86:3000
