# Sound Sentinel Backend Configuration

# Сервер
SOUND_SENTINEL_HOST=0.0.0.0
SOUND_SENTINEL_PORT=8000
SOUND_SENTINEL_DEBUG=false
SOUND_SENTINEL_ENV=development

# SSL
USE_SSL=true
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem

# База данных
DB_PATH=soundsentinel.db

# Детекция
DETECTION_THRESHOLD=0.5
MAX_DETECTIONS_PER_DEVICE=1000

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# CORS
ALLOWED_ORIGINS=*

# Логирование
LOG_LEVEL=INFO
SUPPRESS_TENSORFLOW_WARNINGS=true
