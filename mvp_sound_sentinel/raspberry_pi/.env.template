# Sound Sentinel Raspberry Pi Client Configuration

# Сервер - УКАЖИТЕ ПРАВИЛЬНЫЙ IP АДРЕС ВАШЕГО ПК!
SERVER_HOST=192.168.0.94
SERVER_PORT=8000
USE_SSL=true

# Устройство
DEVICE_NAME=Raspberry Pi Monitor
DEVICE_TYPE=raspberry_pi

# Аудио настройки
SAMPLE_RATE=16000
CHUNK_SIZE=1024
CHANNELS=1
AUDIO_FORMAT=int16
MICROPHONE_DEVICE_INDEX=0
AUTO_SELECT_MICROPHONE=true

# Детекция
DETECTION_INTERVAL=2.0
DETECTION_THRESHOLD=0.5
MIN_AUDIO_LENGTH=1.0
MAX_AUDIO_LENGTH=3.0

# Интервалы отправки данных (в секундах)
AUDIO_LEVEL_UPDATE_INTERVAL=0.5
DEVICE_INFO_UPDATE_INTERVAL=60
WIFI_SIGNAL_UPDATE_INTERVAL=30

# WebSocket
WS_RECONNECT_DELAY=5.0
WS_MAX_RECONNECT_ATTEMPTS=10
WS_PING_INTERVAL=30

# Логирование
LOG_LEVEL=INFO
VERBOSE=false
LOG_TO_FILE=true
LOG_FILE_PATH=audio_client.log

# Статистика
STATS_UPDATE_INTERVAL=300

# Обработка ошибок
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=2.0

# Системные пороги
CPU_USAGE_WARNING_THRESHOLD=80
MEMORY_USAGE_WARNING_THRESHOLD=80
DISK_USAGE_WARNING_THRESHOLD=90

# Окружение
SOUND_SENTINEL_ENV=development
